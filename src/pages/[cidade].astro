---
import Layout from '../layouts/Layout.astro';
import cidades from '../data/cidades.json';

export function getStaticPaths() {
  return cidades.map((c) => ({
    params: { cidade: c.slug },
    props: { cidade: c },
  }));
}

const { cidade: c } = Astro.props;

const assets = {
  logo:        '/images/logo-riviera.png',
  hero:        '/images/hero-jewelry-BvgQUVJ1.jpg',
  correntes:   '/images/item-correntes-BPAOxieA.jpg',
  aneis:       '/images/item-aneis-CZLYbggN.jpg',
  pulseiras:   '/images/item-pulseiras-ByIh7EQE.jpg',
  brincos:     '/images/item-brincos--neZJSdU.jpg',
  relogios:    '/images/item-relogios-uhcWfNzM.jpg',
  ouroQuebrado:'/images/item-ouro-quebrado-XSrMlOmA.jpg',
  ouroAntigo:  '/images/item-ouro-antigo-C5reThlg.jpg',
  sucata:      '/images/item-sucata-C-2AfJAI.jpg',
};

const items = [
  { src: assets.correntes,    alt: 'Correntes de ouro', label: 'Correntes de ouro' },
  { src: assets.aneis,        alt: 'Anéis',             label: 'Anéis' },
  { src: assets.pulseiras,    alt: 'Pulseiras',         label: 'Pulseiras' },
  { src: assets.brincos,      alt: 'Brincos',           label: 'Brincos' },
  { src: assets.relogios,     alt: 'Relógios',          label: 'Relógios' },
  { src: assets.ouroQuebrado, alt: 'Ouro quebrado',     label: 'Ouro quebrado' },
  { src: assets.ouroAntigo,   alt: 'Ouro antigo',       label: 'Ouro antigo' },
  { src: assets.sucata,       alt: 'Sucata de ouro',    label: 'Sucata de ouro' },
];
---

<Layout
  title={c.seo.title}
  description={c.seo.description}
  canonical={c.seo.canonical}
  ogImage={c.seo.ogImage}
  cidade={c.cidade}
  estado={c.estado}
  telefoneRaw={c.telefoneRaw}
  endereco={c.endereco}
  complemento={c.complemento}
  cep={c.cep}
  geoLat={c.geoLat}
  geoLng={c.geoLng}
  instagram={c.instagram}
  horario={c.horarioFuncionamento}
>

<!-- ===== HEADER ===== -->
<header class="site-header">
  <div class="header-inner container">
    <a href="#inicio" class="header-logo-link">
      <img src={assets.logo} alt="Riviera - Compra de Ouro e Acessórios" class="header-logo" />
    </a>

    <nav class="desktop-nav" aria-label="Menu principal">
      {[
        ['#inicio',          'Início'],
        ['#como-funciona',   'Como funciona'],
        ['#o-que-compramos', 'O que compramos'],
        ['#vantagens',       'Vantagens'],
        ['#localizacao',     'Localização'],
        ['#contato',         'Contato'],
      ].map(([href, label]) => (
        <a href={href} class="nav-link">{label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <a href={c.whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-gold header-wa-btn">
        Falar no WhatsApp
      </a>
      <button id="menu-btn" class="menu-btn" aria-label="Abrir menu" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="6"  y2="6" /><line x1="4" x2="20" y1="12" y2="12" /><line x1="4" x2="20" y1="18" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    {[
      ['#inicio',          'Início'],
      ['#como-funciona',   'Como funciona'],
      ['#o-que-compramos', 'O que compramos'],
      ['#vantagens',       'Vantagens'],
      ['#localizacao',     'Localização'],
    ].map(([href, label]) => (
      <a href={href} class="mobile-nav-link">{label}</a>
    ))}
    <a href={c.whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-gold mobile-wa-btn">
      Falar no WhatsApp
    </a>
  </div>
</header>

<main>

  <!-- ===== HERO ===== -->
  <section id="inicio" class="hero-section">
    <div class="hero-bg">
      <img src={assets.hero}
        alt={`Joias de ouro - correntes, anéis, pulseiras e relógios em ${c.cidade}`}
        class="hero-img" loading="eager" />
      <div class="hero-overlay-dark"></div>
      <div class="hero-overlay-gradient"></div>
    </div>

    <div class="hero-content container">
      <img src={assets.logo} alt="Riviera - Compra de Ouro e Acessórios" class="hero-logo" />

      <div class="hero-badge">
        <span class="gold-text">{c.cidade} – {c.estado} • Centro da Cidade</span>
      </div>

      <h1 class="hero-h1 font-serif">
        Compra de ouro em {c.cidade} com a <span class="text-gradient-gold">melhor cotação</span>
      </h1>

      <div class="hero-copy">
        <p class="hero-price text-gradient-gold">
          💰 Pagamos <strong class="hero-price-value">R$420</strong> por grama de ouro maciço<br />(Peças Maciças)
        </p>
        <p class="muted">{c.textosUnicos.heroParagrafo}</p>
        <p class="muted">Avaliação justa, pagamento rápido e negociação transparente.</p>
      </div>

      <a href={c.whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-gold btn-hero shadow-gold">
        <svg viewBox="0 0 24 24" class="wa-icon" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Solicitar cotação no WhatsApp
      </a>
    </div>
  </section>

  <!-- ===== ESPECIALISTAS ===== -->
  <section class="section bg-card">
    <div class="container text-center max-w-3xl">
      <h2 class="section-h2 font-serif">
        Especialistas em <span class="text-gradient-gold">compra de ouro</span> em {c.cidade}
      </h2>
      <p class="muted text-lg leading-relaxed mb-4">{c.textosUnicos.especialistaParagrafo}</p>
      <p class="muted text-lg leading-relaxed">{c.textosUnicos.especialistaParagrafo2}</p>
    </div>
  </section>

  <!-- ===== COMO FUNCIONA ===== -->
  <section id="como-funciona" class="section bg-dark">
    <div class="container">
      <h2 class="section-h2 font-serif text-center">
        Como <span class="text-gradient-gold">funciona</span>
      </h2>
      <div class="steps-grid">

        <div class="step-card">
          <div class="icon-circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
              fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"/>
              <path d="M12 22V12"/><path d="m3.3 7 7.703 4.734a2 2 0 0 0 1.994 0L20.7 7"/><path d="m7.5 4.27 9 5.15"/>
            </svg>
          </div>
          <div class="step-num">Passo 1</div>
          <h3 class="step-h3 font-serif">Traga seu ouro</h3>
          <p class="muted text-sm">Traga seus acessórios de ouro até nossa loja no centro de {c.cidade}.</p>
        </div>

        <div class="step-card">
          <div class="icon-circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
              fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
          </div>
          <div class="step-num">Passo 2</div>
          <h3 class="step-h3 font-serif">Avaliação gratuita</h3>
          <p class="muted text-sm">Realizamos uma avaliação gratuita e transparente do seu ouro.</p>
        </div>

        <div class="step-card">
          <div class="icon-circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
              fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="12" x="2" y="6" rx="2"/>
              <circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/>
            </svg>
          </div>
          <div class="step-num">Passo 3</div>
          <h3 class="step-h3 font-serif">Pagamento na hora</h3>
          <p class="muted text-sm">Receba o pagamento imediatamente, sem burocracia.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== O QUE COMPRAMOS ===== -->
  <section id="o-que-compramos" class="section bg-card">
    <div class="container">
      <h2 class="section-h2 font-serif text-center">
        O que <span class="text-gradient-gold">compramos</span>
      </h2>
      <div class="items-grid">
        {items.map((item) => (
          <div class="item-card">
            <div class="item-img-wrap">
              <img src={item.src} alt={item.alt} loading="lazy" class="item-img" />
            </div>
            <span class="item-label">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== VANTAGENS ===== -->
  <section id="vantagens" class="section bg-dark">
    <div class="container">
      <h2 class="section-h2 font-serif text-center">
        Nossas <span class="text-gradient-gold">vantagens</span>
      </h2>
      <div class="vantagens-grid">

        <div class="vantagem-item">
          <div class="icon-circle icon-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
              fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>
            </svg>
          </div>
          <h3 class="vantagem-h3 font-serif">Melhor cotação de ouro em {c.cidade}</h3>
        </div>

        <div class="vantagem-item">
          <div class="icon-circle icon-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
              fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 15h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 17"/>
              <path d="m7 21 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-4.2 3.9"/>
              <path d="m2 16 6 6"/><circle cx="16" cy="9" r="2.9"/><circle cx="6" cy="5" r="3"/>
            </svg>
          </div>
          <h3 class="vantagem-h3 font-serif">Avaliação sem compromisso</h3>
        </div>

        <div class="vantagem-item">
          <div class="icon-circle icon-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
              fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>
            </svg>
          </div>
          <h3 class="vantagem-h3 font-serif">Pagamento imediato</h3>
        </div>

        <div class="vantagem-item">
          <div class="icon-circle icon-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
              fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
            </svg>
          </div>
          <h3 class="vantagem-h3 font-serif">Atendimento seguro e discreto</h3>
        </div>

        <div class="vantagem-item">
          <div class="icon-circle icon-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
              fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <h3 class="vantagem-h3 font-serif">Localização central</h3>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== BAIRROS ===== -->
  <section class="section bg-card border-top">
    <div class="container text-center max-w-3xl">
      <h2 class="section-h2-sm font-serif">
        Atendemos clientes de toda <span class="text-gradient-gold">{c.cidade} e região</span>
      </h2>
      <p class="muted mb-4">
        Bairros e regiões atendidos: {c.bairrosAtendidos.join(', ')} e mais.
      </p>
      <p class="muted">
        Independente do bairro, venha até o centro de {c.cidade} e aproveite a melhor cotação de ouro da região.
      </p>
    </div>
  </section>

  <!-- ===== ONDE VENDER ===== -->
  <section class="section bg-dark">
    <div class="container text-center max-w-3xl">
      <h2 class="section-h2 font-serif">
        Onde vender ouro em <span class="text-gradient-gold">{c.cidade}</span>?
      </h2>
      <p class="muted text-lg leading-relaxed mb-4">{c.textosUnicos.ondeParagrafo}</p>
      <p class="muted leading-relaxed mb-8">{c.textosUnicos.ondeParagrafo2}</p>
      <a href={c.whatsappLink} target="_blank" rel="noopener noreferrer" class="btn-gold btn-md">
        Entre em contato agora
      </a>
    </div>
  </section>

  <!-- ===== LOCALIZAÇÃO ===== -->
  <section id="localizacao" class="section bg-card">
    <div class="container">
      <h2 class="section-h2 font-serif text-center">
        Nossa <span class="text-gradient-gold">localização</span>
      </h2>
      <div class="localizacao-grid">

        <div class="localizacao-info">
          <div class="info-row">
            <div class="icon-circle icon-sm flex-shrink-0 mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <h3 class="info-h3 font-serif">Endereço</h3>
              <p class="muted">{c.endereco}<br />{c.complemento}<br />{c.cidade} – {c.estado}, {c.cep}</p>
            </div>
          </div>

          <div class="info-row">
            <div class="icon-circle icon-sm flex-shrink-0 mt-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                fill="none" stroke="#DFB03A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.21 12 19.79 19.79 0 0 1 1.14 3.33 2 2 0 0 1 3.1 1.14h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div>
              <h3 class="info-h3 font-serif">Telefone / WhatsApp</h3>
              <a href={`tel:${c.telefoneRaw}`} class="gold-text">{c.telefone}</a>
            </div>
          </div>
        </div>

        <div class="map-wrap">
          <iframe
            src={c.mapsEmbed}
            width="100%" height="100%"
            style="border:0;"
            allowfullscreen loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title={`Localização Riviera - Compra de Ouro em ${c.cidade}`}
          ></iframe>
        </div>

      </div>
    </div>
  </section>

</main>

<!-- ===== FOOTER ===== -->
<footer id="contato" class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src={assets.logo} alt="Riviera - Compra de Ouro e Acessórios" class="footer-logo" />
        <p class="muted text-sm">{c.textosUnicos.footerTagline}</p>
      </div>
      <div>
        <h4 class="footer-h4 font-serif">Endereço</h4>
        <p class="muted text-sm">{c.endereco}<br />{c.complemento}<br />{c.cidade} – {c.estado}, {c.cep}</p>
        <p class="muted text-sm mt-2">Tel: {c.telefone}</p>
      </div>
      <div>
        <h4 class="footer-h4 font-serif">Redes Sociais</h4>
        <a href={c.instagram} target="_blank" rel="noopener noreferrer" class="instagram-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
            fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
          </svg>
          {c.instagramHandle}
        </a>
      </div>
    </div>
    <div class="footer-copy">
      <p class="muted text-xs">© 2026 Riviera – Compra de Ouro e Acessórios. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<!-- ===== WhatsApp FAB ===== -->
<a href={c.whatsappLink} target="_blank" rel="noopener noreferrer" aria-label="Falar no WhatsApp" class="wa-fab">
  <svg viewBox="0 0 24 24" class="wa-icon" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<style>
/* =============================================
   TOKENS
   ============================================= */
:root {
  --gold:        #DFB03A;
  --gold-light:  #F5D680;
  --bg:          #121212;
  --bg-card:     #1a1a1a;
  --fg:          #EDE9DE;
  --muted:       #989181;
  --border:      #2a2a2a;
  --wa-green:    #25D366;
  --radius:      0.75rem;
}

/* =============================================
   BASE
   ============================================= */
*, *::before, *::after { box-sizing: border-box; }

body { background: var(--bg); color: var(--fg); margin: 0; }

.container {
  width: 100%;
  max-width: 1280px;
  margin-inline: auto;
  padding-inline: 1rem;
}

.max-w-3xl { max-width: 48rem; margin-inline: auto; }
.text-center { text-align: center; }
.muted { color: var(--muted); }
.gold-text { color: var(--gold); text-decoration: none; }
.text-sm  { font-size: 0.875rem; }
.text-xs  { font-size: 0.75rem; }
.text-lg  { font-size: 1.1rem; }
.leading-relaxed { line-height: 1.75; }
.mb-4 { margin-bottom: 1rem; }
.mb-8 { margin-bottom: 2rem; }
.mt-1 { margin-top: 0.25rem; }
.mt-2 { margin-top: 0.5rem; }
.flex-shrink-0 { flex-shrink: 0; }
.border-top { border-top: 1px solid var(--border); }

.bg-dark { background: var(--bg); }
.bg-card { background: var(--bg-card); }

/* =============================================
   BUTTONS
   ============================================= */
.btn-gold {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-weight: 600;
  border-radius: 0.5rem;
  text-decoration: none;
  color: #121212;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
  transition: opacity 0.2s;
  cursor: pointer;
  border: none;
  white-space: nowrap;
}
.btn-gold:hover { opacity: 0.9; }

.btn-hero {
  gap: 0.75rem;
  padding: 0.9rem 1.75rem;
  font-size: 1rem;
  font-weight: 700;
}
.btn-md {
  padding: 0.75rem 1.5rem;
  font-size: 1rem;
}

.shadow-gold { box-shadow: 0 4px 20px rgba(223,176,58,0.4); }

/* =============================================
   GRADIENTS
   ============================================= */
.text-gradient-gold {
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 50%, var(--gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* =============================================
   ICON CIRCLES
   ============================================= */
.icon-circle {
  width: 4rem;
  height: 4rem;
  border-radius: 50%;
  background: rgba(223,176,58,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.icon-sm {
  width: 3rem;
  height: 3rem;
}

/* =============================================
   HEADER
   ============================================= */
.site-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 50;
  background: rgba(18,18,18,0.96);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 4rem;
}
.header-logo-link { display: flex; align-items: center; }
.header-logo { height: 3rem; border-radius: 0.375rem; }

.desktop-nav {
  display: none;
  align-items: center;
  gap: 2rem;
}
.nav-link {
  font-size: 0.875rem;
  font-weight: 500;
  color: rgba(237,233,222,0.7);
  text-decoration: none;
  transition: color 0.2s;
}
.nav-link:hover { color: var(--gold); }

.header-actions { display: flex; align-items: center; gap: 0.75rem; }
.header-wa-btn {
  display: none;
  padding: 0.5rem 1rem;
  font-size: 0.8125rem;
}
.menu-btn {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--fg);
  padding: 0.5rem;
  display: flex;
  align-items: center;
}

/* Mobile menu */
.mobile-menu {
  display: none;
  flex-direction: column;
  gap: 0.25rem;
  padding: 1rem;
  border-top: 1px solid var(--border);
}
.mobile-menu.open { display: flex; }

.mobile-nav-link {
  color: rgba(237,233,222,0.7);
  text-decoration: none;
  font-size: 0.9375rem;
  padding: 0.625rem 0;
  border-bottom: 1px solid rgba(42,42,42,0.5);
}
.mobile-nav-link:hover { color: var(--gold); }
.mobile-wa-btn {
  margin-top: 0.75rem;
  padding: 0.75rem 1rem;
  font-size: 0.9375rem;
  width: 100%;
}

/* =============================================
   HERO
   ============================================= */
.hero-section {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.hero-bg { position: absolute; inset: 0; }
.hero-img { width: 100%; height: 100%; object-fit: cover; }
.hero-overlay-dark {
  position: absolute; inset: 0;
  background: rgba(18,18,18,0.75);
}
.hero-overlay-gradient {
  position: absolute; inset: 0;
  background: linear-gradient(to top, #121212 0%, rgba(18,18,18,0.35) 45%, transparent 100%);
}

.hero-content {
  position: relative;
  z-index: 10;
  padding-top: 6rem;
  padding-bottom: 3rem;
  text-align: center;
}
.hero-logo {
  height: 5rem;
  border-radius: 0.375rem;
  margin: 0 auto 1.5rem;
  display: block;
}
.hero-badge {
  display: inline-block;
  margin-bottom: 1.25rem;
  padding: 0.375rem 1rem;
  border: 1px solid rgba(223,176,58,0.35);
  border-radius: 9999px;
  font-size: 0.8125rem;
  font-weight: 500;
}
.hero-h1 {
  font-size: clamp(1.75rem, 5vw, 4rem);
  font-weight: 700;
  line-height: 1.15;
  margin: 0 auto 1.5rem;
  max-width: 52rem;
}
.hero-copy {
  max-width: 40rem;
  margin: 0 auto 2rem;
}
.hero-price {
  font-size: clamp(1rem, 2.5vw, 1.25rem);
  font-weight: 700;
  margin-bottom: 0.75rem;
  line-height: 1.4;
}
.hero-price-value {
  font-size: clamp(1.5rem, 5vw, 2.75rem);
  font-weight: 900;
}

/* =============================================
   SECTIONS
   ============================================= */
.section { padding: 4rem 0; }
.section-h2 {
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 700;
  margin-bottom: 2.5rem;
}
.section-h2-sm {
  font-size: clamp(1.25rem, 2.5vw, 1.6rem);
  font-weight: 700;
  margin-bottom: 1.25rem;
}

/* =============================================
   COMO FUNCIONA
   ============================================= */
.steps-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
  max-width: 56rem;
  margin-inline: auto;
}
.step-card {
  text-align: center;
  padding: 1.75rem 1.5rem;
  border-radius: var(--radius);
  border: 1px solid var(--border);
  background: var(--bg-card);
  transition: border-color 0.2s;
}
.step-card:hover { border-color: rgba(223,176,58,0.3); }
.icon-circle { margin: 0 auto 1.25rem; }
.step-num {
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--gold);
  margin-bottom: 0.5rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.step-h3 {
  font-size: 1.2rem;
  font-weight: 700;
  margin: 0 0 0.75rem;
}

/* =============================================
   O QUE COMPRAMOS
   ============================================= */
.items-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
  max-width: 56rem;
  margin-inline: auto;
}
.item-card {
  border-radius: var(--radius);
  border: 1px solid var(--border);
  overflow: hidden;
  background: var(--bg);
  transition: border-color 0.2s;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.item-card:hover { border-color: rgba(223,176,58,0.3); }
.item-img-wrap { width: 100%; aspect-ratio: 1; overflow: hidden; }
.item-img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform 0.5s;
  display: block;
}
.item-card:hover .item-img { transform: scale(1.06); }
.item-label {
  font-size: 0.8125rem;
  font-weight: 500;
  text-align: center;
  padding: 0.625rem 0.5rem;
}

/* =============================================
   VANTAGENS
   ============================================= */
.vantagens-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  max-width: 64rem;
  margin-inline: auto;
}
.vantagem-item {
  text-align: center;
  padding: 1.25rem 1rem;
}
.vantagem-h3 {
  font-size: 0.875rem;
  font-weight: 700;
  line-height: 1.4;
  margin: 0;
}
.icon-sm { margin: 0 auto 0.875rem; }

/* =============================================
   LOCALIZAÇÃO
   ============================================= */
.localizacao-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  max-width: 64rem;
  margin-inline: auto;
  align-items: center;
}
.localizacao-info {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.info-row {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}
.info-h3 {
  font-size: 1.05rem;
  font-weight: 700;
  margin: 0 0 0.25rem;
}
.map-wrap {
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
  height: 18rem;
}

/* =============================================
   FOOTER
   ============================================= */
.site-footer {
  padding: 3rem 0;
  border-top: 1px solid var(--border);
  background: rgba(26,26,26,0.5);
}
.footer-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
  align-items: start;
}
.footer-brand img { border-radius: 0.375rem; margin-bottom: 0.75rem; }
.footer-logo { height: 4rem; }
.footer-h4 { font-weight: 700; margin: 0 0 0.75rem; }
.footer-copy {
  margin-top: 2rem;
  padding-top: 1.25rem;
  border-top: 1px solid var(--border);
  text-align: center;
}
.instagram-link {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--muted);
  text-decoration: none;
  font-size: 0.875rem;
  transition: color 0.2s;
}
.instagram-link:hover { color: var(--gold); }

/* =============================================
   WhatsApp FAB
   ============================================= */
.wa-fab {
  position: fixed;
  bottom: 1.25rem;
  right: 1.25rem;
  z-index: 50;
  width: 3.25rem;
  height: 3.25rem;
  background: var(--wa-green);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(37,211,102,0.4);
  text-decoration: none;
  transition: box-shadow 0.2s, transform 0.2s;
}
.wa-fab:hover { box-shadow: 0 6px 24px rgba(37,211,102,0.5); transform: scale(1.05); }
.wa-icon { width: 1.6rem; height: 1.6rem; fill: white; }

/* =============================================
   BREAKPOINTS
   ============================================= */

/* ---- 480px: small phones ---- */
@media (min-width: 480px) {
  .hero-logo { height: 6rem; }
  .btn-hero { padding: 1rem 2rem; font-size: 1.0625rem; }
  .wa-fab { width: 3.5rem; height: 3.5rem; }
  .wa-icon { width: 1.75rem; height: 1.75rem; }
}

/* ---- 640px: large phones / small tablets ---- */
@media (min-width: 640px) {
  .header-logo { height: 3.5rem; }
  .hero-logo { height: 7rem; }
  .steps-grid { grid-template-columns: repeat(3, 1fr); }
  .items-grid { grid-template-columns: repeat(4, 1fr); }
  .vantagens-grid { grid-template-columns: repeat(3, 1fr); }
  .map-wrap { height: 22rem; }
}

/* ---- 768px: tablets ---- */
@media (min-width: 768px) {
  .header-inner { height: 5rem; }
  .header-logo { height: 4rem; }
  .header-wa-btn { display: inline-flex; }
  .section { padding: 5rem 0; }
  .hero-content { padding-top: 7rem; }
  .footer-grid { grid-template-columns: repeat(3, 1fr); }
  .localizacao-grid { grid-template-columns: 1fr 1fr; }
  .map-wrap { height: 20rem; }
  .vantagens-grid { grid-template-columns: repeat(5, 1fr); }
  .wa-fab { bottom: 1.5rem; right: 1.5rem; }
}

/* ---- 1024px: desktop ---- */
@media (min-width: 1024px) {
  .desktop-nav { display: flex; }
  .menu-btn { display: none; }
  .hero-logo { height: 8rem; }
  .section-h2 { margin-bottom: 3.5rem; }
  .steps-grid { gap: 2rem; }
  .items-grid { gap: 1rem; }
  .map-wrap { height: 22rem; }
}
</style>

<script>
  const btn  = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(isOpen));
    menu?.setAttribute('aria-hidden', String(!isOpen));
  });

  // Close mobile menu when clicking a link
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
</script>

</Layout>
